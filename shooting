<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Rian's Game</title>
  <style>
    body {
      background: #111;
      color: white;
      text-align: center;
      font-family: sans-serif;
    }
    canvas {
      border: 2px solid white;
      margin-top: 20px;
    }
  </style>
</head>
<body>
  <h1>Rian's Shooting Game</h1>

  <canvas id="game" width="300" height="300"></canvas>

  <!-- ここにゲームの JavaScript を入れる -->
  <script>
    const c = document.getElementById("game")
    const ctx = c.getContext("2d")

    let x = 150
    let y = 250
    const speed = 3
    const size = 20
    let keys = {}
    let bullet=[]
    let ptime=0
    const pinterval=20

    let enemies=[]
    let etime=0
    let einterval=120
    let ebullet=[]

    let bossx=130
    let bossy=-100
    let bossapear=false
    let bossready=false
    let bosstime=0
    let homingshottime=0
    let homingshottinterval=80
    let spreadshottime=0
    let spreadshotinterval=200
    let straighttime=0
    let straightinterval=200
    let straightduring=0
    let straightduringinterval=240
    let flash = 0;
    let flashInterval = 60;
    let flashSide = null;
    let bosshp=30
    let death=false

    function straightbullet(x,y){
      ebullet.push({
        x:x+size/2-5,
        y:y+size,
        w:10,
        h:10,
        dx:0,
        dy:4
      })
    }

    function homingbullet(ex,ey){
      let dx=x-ex
      let dy=y-ey
      let len=Math.sqrt(dx*dx+dy*dy)

      dx=dx/len
      dy=dy/len

      ebullet.push({
        x:ex+size/2-5,
        y:ey+size,
        w:10,
        h:10,
        dx:dx*2.5,
        dy:dy*2.5,
      })
    }

    function spreadbullet(ex, ey) {
      const angles = [-30,-15, 0,15,  30];
      const speed = 4;

      for (let a of angles) {
        let rad = (a+90) * Math.PI / 180;
        let dx = Math.cos(rad) * speed;
        let dy = Math.sin(rad) * speed;

        ebullet.push({
          x: ex + size/2 - 5,
          y: ey + size,
          w: 10,
          h:10,
          dx: dx,
          dy: dy
        });
      }
    }

    function beam(x,y){
      ebullet.push({
        x:x+size/2-5,
        y:y+size,
        w:10,
        h:10,
        dx:0,
        dy:15
      })
    }

    let leveltimer=0
    let levelinterval=400
    let score=0
    let gameover=false

    function hit(a,b){
      return(
        a.x < b.x + b.w &&
        a.x + a.w > b.x &&
        a.y < b.y + b.h &&
        a.y + a.h > b.y
      )
    }

    function GAMEOVER(){
      x=150
      y=250
      bullet=[]
      enemies=[]
      ebullet=[]
      etime=0
      einterval=120
      ptime=0
      leveltimer=0
      levelinterval=400
      score=0
      gameover=false
      death=false
      draw()
    }

    document.addEventListener("keydown", (e) => {
      keys[e.key] = true

      if(keys["r"] && (gameover || death )){
        GAMEOVER()
      }
    })

    document.addEventListener("keyup", (e) => {
      keys[e.key] = false
    })

    function loop(){
      ctx.clearRect(0,0,c.width,c.height)

      ctx.fillStyle="white"
      ctx.font="15px Arial"
      ctx.fillText("score:"+score,200,20)

      if(death){
        ctx.fillStyle="white"
        ctx.font="40px Arial"
        ctx.fillText("GAME CLEAR",50,150)
        return
      }

      if(gameover){
        ctx.fillStyle="white"
        ctx.font="40px Arial"
        ctx.fillText("GAME OVER",50,150)
        ctx.font="20px Arial"
        ctx.fillText("Press R to Restart", 60, 200)
        return
      }

      if(keys["ArrowRight"] && x < 280) x += speed
      if(keys["ArrowLeft"] && x > 0 ) x -= speed
      if(keys["ArrowDown"] && y < 280 ) y += speed
      if(keys["ArrowUp"] && y > 0 ) y -= speed

      ptime++

      if(keys["z"] && ptime>pinterval){
        bullet.push({
          x:x+size/2-5,
          y:y,
          speed:6,
          w:10,
          h:10
        })
        ptime=0
      }

      ctx.fillStyle="yellow"
      for(let b of bullet){
        b.y -= b.speed
        ctx.fillRect(b.x,b.y,b.w,b.h)
      }
      bullet = bullet.filter(b=>b.y>-20)

      etime++
      if(etime>einterval && score<2500){
        enemies.push({
          x:Math.random()*270,
          y:-30,
          w:30,
          h:30,
          speed:0.5,
          shottimer:0,
          type:Math.random()<0.2 ? "homing" : 
               Math.random()<0.4 ? "spread" : "straight"
        })
        etime=0
      }

      for(let e of enemies){
        if(hit({x:x,y:y,w:size,h:size},{x:e.x,y:e.y,w:e.w,h:e.h})) gameover=true

        e.y += e.speed
        ctx.fillStyle = e.type==="homing" ? "purple" :
                        e.type==="straight" ? "red" : "green"
        ctx.fillRect(e.x,e.y,e.w,e.h)

        e.shottimer++
        if(e.shottimer>120){
          if(e.type==="homing") homingbullet(e.x,e.y)
          else if(e.type==="straight") straightbullet(e.x,e.y)
          else spreadbullet(e.x,e.y)
          e.shottimer=0
        }
      }

      ctx.fillStyle="darkred"
      ctx.fillRect(bossx,bossy,15,70)
      ctx.fillRect(bossx+30,bossy+10,15,40)
      ctx.fillRect(bossx-30,bossy+10,15,40)
      ctx.fillRect(bossx-30,bossy+20,70,15)

      if(score>=2500) bossapear=true
      if(bossapear && bossy<30) bossy+=0.5
      if(bossy===30) bossready=true

      if(bossready){
        bosstime++
        bossx=Math.sin(bosstime/40)*100+130
      }

      homingshottime++
      if(homingshottime>homingshottinterval && bossready){
        homingbullet(bossx,bossy+40)
        homingshottime=0
      }

      requestAnimationFrame(loop)
    }
    loop()
  </script>
</body>
</html>
